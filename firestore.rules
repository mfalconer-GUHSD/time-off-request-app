rules_version = '2';

// -----------------------------------------------------------------------
// Comp Time Tracker — Firestore Security Rules
//
// Data model:
//   users/{uid}            -> { email, name, school, isManagerFor: [schoolId,...], isSuperAdmin: bool }
//   schools/{schoolId}      -> { name }
//   earnedRequests/{id}     -> earned comp-time entries
//   usedRequests/{id}       -> comp-time usage requests
//   auditLog/{id}           -> append-only activity log
//
// NOTE ON ARCHITECTURE: this app runs on Firebase's free Spark plan with
// no Cloud Functions (no billing account). That means there is no trusted
// server recomputing the OT/straight-time comp-hour math — the client
// computes it, and these rules validate the arithmetic on write as a
// backstop against a tampered or buggy client. It's a weaker guarantee
// than a Cloud Function recomputing it independently, but keeps the
// worst case bounded to "obviously wrong values are rejected" rather than
// "no check at all." FIFO consumption similarly runs as a client-side
// Firestore transaction (executed under the approving manager's own
// authenticated session) rather than an Admin-SDK transaction.
// -----------------------------------------------------------------------

function isSignedIn() {
  return request.auth != null;
}

function isDistrictAccount() {
  return isSignedIn() && request.auth.token.email.matches('.*@guhsd[.]net$');
}

function myUserDoc() {
  return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
}

function isSuperAdmin() {
  return isDistrictAccount() && myUserDoc().isSuperAdmin == true;
}

function isManagerFor(schoolId) {
  return isDistrictAccount() && schoolId in myUserDoc().isManagerFor;
}

// Validates the OT/straight-time comp-hour math submitted by the client
// matches the district's actual formula: 1.5x if regular hours worked
// that day > 0 (true overtime), 1.0x if 0 (e.g. a weekend event).
function compHoursMathIsValid(data) {
  let expectedExact = data.regularHours > 0 ? data.extraHours * 1.5 : data.extraHours * 1.0;
  return data.compHoursExact == expectedExact &&
         data.compHoursRounded >= expectedExact - 0.125 &&
         data.compHoursRounded <= expectedExact + 0.125 &&
         data.remainingHours == data.compHoursRounded;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // Each person can read/update their own profile (but not grant
    // themselves manager/superadmin rights — only a superadmin can do that).
    match /users/{uid} {
      allow read: if isDistrictAccount() && (request.auth.uid == uid || isSuperAdmin());
      allow create: if isDistrictAccount() && request.auth.uid == uid &&
        request.resource.data.isManagerFor == [] &&
        request.resource.data.isSuperAdmin == false;
      allow update: if isDistrictAccount() && (
        (request.auth.uid == uid &&
          request.resource.data.isManagerFor == resource.data.isManagerFor &&
          request.resource.data.isSuperAdmin == resource.data.isSuperAdmin)
        || isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Read-only list of GUHSD schools, maintained by a superadmin.
    match /schools/{schoolId} {
      allow read: if isDistrictAccount();
      allow write: if isSuperAdmin();
    }

    // Earned comp-time entries.
    match /earnedRequests/{id} {
      allow read: if isDistrictAccount() && (
        resource.data.employeeId == request.auth.uid ||
        isManagerFor(resource.data.school) ||
        isSuperAdmin()
      );
      // Employee creates their own; comp-hour math is validated here since
      // there's no Cloud Function to recompute it authoritatively.
      allow create: if isDistrictAccount() &&
        request.resource.data.employeeId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        compHoursMathIsValid(request.resource.data);
      // Managers (for FIFO drawdown + approve/reject) and superadmins can
      // update. Employees cannot edit their own submission once created.
      allow update: if isDistrictAccount() &&
        (isManagerFor(resource.data.school) || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // Comp-time usage requests.
    match /usedRequests/{id} {
      allow read: if isDistrictAccount() && (
        resource.data.employeeId == request.auth.uid ||
        isManagerFor(resource.data.school) ||
        isSuperAdmin()
      );
      allow create: if isDistrictAccount() &&
        request.resource.data.employeeId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.totalHours > 0;
      allow update: if isDistrictAccount() &&
        (isManagerFor(resource.data.school) || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // Append-only audit trail. Nobody edits or deletes history.
    match /auditLog/{id} {
      allow read: if isDistrictAccount();
      allow create: if isDistrictAccount();
      allow update, delete: if false;
    }
  }
}
